# Razorpay publishable key (optional — create-order API returns key_id from backend)
# VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id

# --- Razorpay LIVE payments on deployed site (required) ---
# 1. Razorpay Dashboard → Account & Settings → Website & App settings
#    Add EVERY URL users open checkout from (exact host + https), e.g.:
#    https://yourdomain.com  and  https://www.yourdomain.com
#    If checkout runs from an IP or staging URL, register that too.
# 2. Use rzp_live_* keys on the server (backend/.env), not test keys.
# 3. Rebuild the frontend after changing VITE_* (Vite bakes env at build time).

# Backend API URL. When set, panel + payment APIs use this (auth via Supabase JWT).
# Local dev:
# VITE_API_URL=http://localhost:3001
# Production build (Render/VPS) — must NOT be localhost:
# VITE_API_URL=https://api.yourdomain.com
# or http://207.180.226.196:3001 if API is on VPS IP only

# Supabase (optional). When set, login uses Supabase Auth and public.user_roles for role/prant.
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_public_key
