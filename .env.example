# Backend API URL. When set, panel uses this for content/complaints/prants (auth via Supabase JWT).
# VITE_API_URL=http://localhost:3001
# For backend on VPS:
# VITE_API_URL=http://207.180.226.196:3001

# Supabase (optional). When set, login uses Supabase Auth and public.user_roles for role/prant.
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_public_key
