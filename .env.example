# Backend API URL (optional in local dev — Vite proxies /api → localhost:3001).
# REQUIRED for production build — set to your deployed API, NOT localhost:
# VITE_API_URL=https://api.yourdomain.com
# or: VITE_API_URL=http://207.180.226.196:3001

# Razorpay: NEVER put RAZORPAY_KEY_SECRET here. Use backend/.env only.
# Public key is returned by /api/donation/create-order — no VITE_RAZORPAY_* needed.

# Supabase (optional). When set, login uses Supabase Auth and public.user_roles for role/prant.
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_public_key
