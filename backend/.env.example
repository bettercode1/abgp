# PostgreSQL on VPS (tables in schema "abgp": prant_profiles, content, complaints)
DATABASE_URL=postgresql://USER:PASSWORD@207.180.226.196:5432/DATABASE_NAME

# Supabase (auth only): verify JWTs and read user_roles / admin auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-project-settings-api
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-project-settings-api

# API port (backend listens on 0.0.0.0 so reachable via VPS IP)
PORT=3001

# Razorpay (server-side only — never expose KEY_SECRET to the frontend)
# Use rzp_test_* keys for local development; rzp_live_* for production.
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Membership fee in paise (amount is set only on the server).
# Production (NODE_ENV=production): defaults to 10000 (₹100) when unset.
# Local dev: defaults to 10000 (₹100) when unset. Override explicitly if needed:
# MEMBERSHIP_AMOUNT_PAISE=10000
